# ─── SITE ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.yourfirm.com
NEXT_PUBLIC_SITE_NAME=Tocado Real Estate

# ─── IDX / MLS ──────────────────────────────────────────
# Provider options: mock | matrix-iframe | mls-grid | bridge-api
IDX_PROVIDER=mock

# Matrix IDX (Canopy MLS frameable search). Paste the iframe URL your mom's IDX gives her.
NEXT_PUBLIC_IDX_IFRAME_SRC=

# If she sends a full <script>/widget snippet instead of an iframe URL, paste it here.
IDX_WIDGET_HTML=

# MLS Grid (RESO Web API) — server-side only, never exposed to the browser
MLS_GRID_BASE_URL=
MLS_GRID_TOKEN=

# Bridge API (alternative RESO provider)
BRIDGE_API_BASE_URL=
BRIDGE_API_TOKEN=

# ─── LEADS / CRM ────────────────────────────────────────
# Webhook all form submissions POST to (GoHighLevel, Follow Up Boss, Zapier, Make, etc.)
CRM_WEBHOOK_URL=
FORM_TO_EMAIL=

# ─── TRACKING ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ─── HOME VALUATION (RentCast AVM) ──────────────────────
# Free key at https://app.rentcast.io  → add in Cloudflare Pages → Variables
RENTCAST_API_KEY=

# ─── NEIGHBORHOOD MAPS (Google Maps + Places) ──────────
# Build var in Cloudflare Pages. Enable Maps JavaScript API + Places API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
